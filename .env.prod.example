# PRODUKCIJSKI .env — template za server (homeos.imel.cloud).
#
# NE commituje se sa pravim vrijednostima. Kopira se JEDNOM ručno na server kao
# `.env` u DEPLOY_PATH, popuni pravim tajnama, i tamo ostaje trajno. deploy.yml ga
# NE dira (git pull ne prepisuje .env jer je .env u .gitignore).
#
# Postavljanje na serveru (jednom):
#   cp .env.prod.example .env
#   nano .env                     # popuni APP_KEY, DB_PASSWORD, RESEND_KEY
#   # APP_KEY: generiši jednom i NE mijenjaj ga poslije (mijenjanje razbija
#   # postojeće sesije i enkriptovane podatke):
#   docker compose -f docker-compose.prod.yml run --rm app php artisan key:generate --show
#   # pa upiši dobijenu vrijednost u APP_KEY.

APP_NAME="Home OS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Sarajevo
APP_LOCALE=bs
APP_URL=https://homeos.imel.cloud

# Baza: postojeći MariaDB na HOSTU (nije kontejner). Kontejner mu pristupa preko
# host.docker.internal (docker-compose.prod.yml ima extra_hosts host-gateway).
# VAŽNO (server-side, vidi napomenu u README/uputama): MariaDB mora slušati i na
# docker bridge adresi (ne samo 127.0.0.1), a `homeos` korisniku mora biti dozvoljen
# pristup sa docker podmreže — inače kontejner ne može doći do baze.
DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=homeosdb
DB_USERNAME=homeos
DB_PASSWORD=

REDIS_HOST=redis
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# Resend (domen homeos.imel.cloud verifikovan u Resend dashboardu, SPF/DKIM na
# Hurricane Electric DNS-u — vidi CLAUDE.md tačku 3).
MAIL_MAILER=resend
RESEND_KEY=
MAIL_FROM_ADDRESS="notifications@homeos.imel.cloud"
MAIL_FROM_NAME="${APP_NAME}"

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080

# Interni port na kom Nginx sluša (mapiran na 127.0.0.1 na hostu; Apache/Virtualmin
# radi reverse proxy ka ovom portu). Mora se poklapati sa ProxyPass direktivom.
APP_INTERNAL_PORT=8091
